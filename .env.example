# Canvas / Carmen (generate at: https://osu.instructure.com/profile/settings -> New Access Token)
CANVAS_BASE_URL=https://osu.instructure.com
CANVAS_TOKEN=

# Google Gemini — FREE, no credit card needed
# Get your API key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# Twilio — OPTIONAL, for outbound SMS/Apple Watch alerts
# Primary interface is the web dashboard at http://localhost:5000
# Sign up at: https://www.twilio.com/try-twilio (free trial ~$15 credit)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=    # your Twilio number e.g. +15551234567
YOUR_PHONE_NUMBER=      # your real number e.g. +18474142199

# Piazza (optional — only needed if a course uses Piazza)
PIAZZA_EMAIL=
PIAZZA_PASSWORD=
PIAZZA_NETWORK_ID=      # visible in Piazza URL for your class

# Schedule preferences
DIGEST_HOUR=14          # 2pm daily SMS digest (only if Twilio configured)
WAKE_HOUR=12            # don't schedule work before this hour
NO_WORK_AFTER_HOUR=22   # don't schedule work after this hour
BUFFER_DAYS=1           # aim to finish this many days before due date

# Web dashboard
WEB_PORT=5000           # open http://localhost:5000 in your browser
